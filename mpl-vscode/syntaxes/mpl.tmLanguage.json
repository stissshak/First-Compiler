{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MPL",
  "scopeName": "source.mpl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#builtins" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mpl",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.mpl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.include.mpl",
          "match": "^\\s*(#\\s*include)\\b\\s*(\"[^\"]*\")?",
          "captures": {
            "1": { "name": "keyword.control.directive.include.mpl" },
            "2": { "name": "string.quoted.double.include.mpl" }
          }
        },
        {
          "name": "meta.preprocessor.mpl",
          "match": "^\\s*(#\\s*(?:define|ifdef|ifndef|endif|else|undef|pragma))\\b",
          "captures": {
            "1": { "name": "keyword.control.directive.mpl" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mpl",
          "match": "\\b(if|else|for|do|while|switch|case|default|return|break|continue)\\b"
        },
        {
          "name": "keyword.operator.sizeof.mpl",
          "match": "\\b(sizeof|typeid)\\b"
        },
        {
          "name": "storage.modifier.mpl",
          "match": "\\b(const|static|extern)\\b"
        },
        {
          "name": "keyword.other.mpl",
          "match": "\\b(typedef|struct|union|enum)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.mpl",
          "match": "\\b(int|uint|float|char|void|bool|byte|short|long)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.mpl",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.mpl",
          "match": "\\b(print|input|exit|panic|assert|malloc|free)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.mpl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.mpl",
          "match": "\\\\(x[0-9A-Fa-f]{2}|[0-7]{1,3}|[\\\\\"'nrtbfva0]|.)"
        },
        {
          "name": "constant.other.placeholder.mpl",
          "match": "%[-+ #0]*[0-9]*(?:\\.[0-9]+)?[diouxXeEfFgGcsp%]"
        }
      ]
    },
    "chars": {
      "name": "string.quoted.single.mpl",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.mpl",
          "match": "\\\\(x[0-9A-Fa-f]{2}|[0-7]{1,3}|[\\\\\"'nrtbfva0]|.)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.mpl",
          "match": "\\b0[xX][0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.binary.mpl",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.float.mpl",
          "match": "\\b[0-9]+\\.[0-9]+([eE][-+]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.mpl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "name": "meta.function-call.mpl",
          "captures": {
            "1": { "name": "entity.name.function.mpl" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.mpl",
          "match": "(\\.\\.\\.|->|\\+\\+|--|<<=|>>=|<<|>>|&&|\\|\\||==|!=|<=|>=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|[-+*/%&|\\^~!<>=?:])"
        }
      ]
    }
  }
}
